# Flask secret key (use a long random string in production)
SECRET_KEY=your-secret-key-here
CSRF_SECRET_KEY=your-csrf-secret-here

# Database connection URI
# MySQL example: mysql+pymysql://user:password@localhost:3306/dbname
# SQLite example: sqlite:///app.db
SQLALCHEMY_DATABASE_URI=sqlite:///app.db

# API server connection (used by the user app to talk to the API app)
API_HOST=127.0.0.1
API_PORT=8000

# JWT authentication
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRY_HOURS=24

# Firebase Cloud Messaging (optional — leave empty to disable push notifications)
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=

# Google Maps API Key (for dashboard live map)
GOOGLE_MAPS_API_KEY=
